{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "bash ${CLAUDE_PLUGIN_ROOT}/vault-assets/hooks/check-obsidian.sh",
						"async": true
					}
				]
			}
		],
		"Notification": [
			{
				"matcher": "idle_prompt",
				"hooks": [
					{
						"type": "command",
						"command": "bash ${CLAUDE_PLUGIN_ROOT}/vault-assets/hooks/notify-complete.sh",
						"async": true
					}
				]
			}
		]
	}
}
